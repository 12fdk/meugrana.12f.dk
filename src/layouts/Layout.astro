---
// Shared page shell: head metadata, favicons, stylesheet, Umami analytics.
// Pages pass their own title/description/canonical and extend the head via
// the named "head" slot (OG tags, structured data, extra styles).
import { SITE, ORG_ID, WEBSITE_ID, APP_STORE_URL } from "../consts";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  /** Load css/style.css (the site stylesheet). The 404 page opts out. */
  siteStylesheet?: boolean;
  /** Load the Umami analytics script. The 404 page opts out. */
  analytics?: boolean;
}

const {
  title,
  description,
  canonical,
  noindex = false,
  siteStylesheet = true,
  analytics = true,
} = Astro.props;

// Site-wide brand entity graph: Organization + WebSite, referenced by
// page-level schema (SoftwareApplication author, BlogPosting publisher)
// via their @id anchors from consts.ts.
const siteEntities = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": ORG_ID,
      name: "MeuGrana",
      url: `${SITE}/`,
      logo: {
        "@type": "ImageObject",
        url: `${SITE}/images/app-icon.png`,
      },
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer support",
        email: "support@12f.dk",
        availableLanguage: ["Portuguese", "English"],
      },
      sameAs: [APP_STORE_URL, "https://12f.dk"],
    },
    {
      "@type": "WebSite",
      "@id": WEBSITE_ID,
      name: "MeuGrana",
      url: `${SITE}/`,
      inLanguage: "pt-BR",
      publisher: { "@id": ORG_ID },
    },
  ],
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#006B4F" />
    {noindex && <meta name="robots" content="noindex" />}

    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    {siteStylesheet && <link rel="stylesheet" href="/css/style.css" />}

    <!-- Brand entity graph (Organization + WebSite) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteEntities)} />

    <slot name="head" />

    {
      analytics && (
        <script
          is:inline
          defer
          src="https://umami.robert-jensen.dk/script.js"
          data-website-id="6c5c421d-2eb8-4e0e-b1a3-3d945360f67f"
        />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
