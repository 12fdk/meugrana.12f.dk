---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { SITE, ORG_ID } from "../../consts";
import { getPublishedPosts, postUrl, formatDate } from "../../utils/blog";
import { readingTime } from "../../utils/readingTime";

const posts = await getPublishedPosts();

const title = "Blog do MeuGrana — parcelas, cartões e finanças no Brasil";
const description =
  "Guias práticos sobre parcelas, fatura do cartão e controle financeiro do jeito brasileiro.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog do MeuGrana",
  description,
  url: `${SITE}/blog/`,
  inLanguage: "pt-BR",
  publisher: { "@id": ORG_ID },
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    url: `${SITE}${postUrl(post)}`,
    datePublished: post.data.publishDate.toISOString().slice(0, 10),
    author: { "@type": "Person", name: post.data.author },
  })),
};
---

<Layout title={title} description={description} canonical={`${SITE}/blog/`}>
  <Fragment slot="head">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}/images/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${SITE}/blog/`} />
    <meta property="og:site_name" content="MeuGrana" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/images/og-image.png`} />
    <link rel="alternate" type="application/rss+xml" title="Blog do MeuGrana" href="/rss.xml" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <Navbar root />

  <main class="blog-index">
    <div class="container">
      <header class="blog-index-header">
        <h1>Blog do MeuGrana</h1>
        <p>Parcelas, fatura do cartão e controle financeiro — do jeito brasileiro.</p>
      </header>
      {
        posts.length === 0 ? (
          <p class="blog-empty">Em breve: guias práticos sobre parcelas e finanças.</p>
        ) : (
          <div class="blog-grid">
            {posts.map((post) => (
              <a class="blog-card" href={postUrl(post)}>
                {post.data.cover && (
                  <img
                    class="blog-card-cover"
                    src={post.data.cover}
                    alt={post.data.coverAlt ?? ""}
                    width="1200"
                    height="700"
                    loading="lazy"
                  />
                )}
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="blog-meta">
                  <time datetime={post.data.publishDate.toISOString().slice(0, 10)}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  {" · "}
                  {readingTime(post.body ?? "")} min de leitura
                </span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </main>

  <Footer root />

  <script is:inline src="/js/main.js"></script>
</Layout>
