---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Screenshots from "../components/Screenshots.astro";
import Testimonials from "../components/Testimonials.astro";
import Premium from "../components/Premium.astro";
import Faq from "../components/Faq.astro";
import DownloadCta from "../components/DownloadCta.astro";
import Footer from "../components/Footer.astro";
import { SITE, APP_STORE_URL } from "../consts";
import { fetchAppStoreData, MIN_RATING_COUNT } from "../utils/appStoreData";

const title = "MeuGrana — Parcelas & Finanças";
const description =
  "O app de finanças feito para o Brasil. Acompanhe parcelas, cartões de crédito e projete suas faturas futuras.";

const appStore = await fetchAppStoreData();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "MeuGrana",
  alternateName: "MeuGrana: Parcelas & Finanças",
  operatingSystem: "iOS",
  applicationCategory: "FinanceApplication",
  description,
  url: `${SITE}/`,
  image: `${SITE}/images/og-image.png`,
  screenshot: [1, 2, 3, 4, 5].map((n) => `${SITE}/images/screenshots/pt-BR/screenshot-${n}.png`),
  featureList: [
    "Installment tracking (parcelas)",
    "Credit card bill projection (12 months)",
    "PIX, boleto, meal voucher support",
    "Monthly dashboard with spending charts",
    "Custom categories",
    "CSV export",
    "iCloud sync (Premium)",
  ],
  inLanguage: ["pt-BR", "en-US"],
  availableCountry: "BR",
  offers: [
    { "@type": "Offer", price: "0", priceCurrency: "BRL", name: "Free" },
    {
      "@type": "Offer",
      price: "14.90",
      priceCurrency: "BRL",
      name: "Premium",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: "14.90",
        priceCurrency: "BRL",
        billingDuration: "P1M",
      },
    },
  ],
  installUrl: APP_STORE_URL,
  author: { "@type": "Organization", name: "MeuGrana", url: `${SITE}/` },
  // Only claim a rating once there are enough reviews to be credible.
  ...(appStore.rating > 0 && appStore.ratingCount >= MIN_RATING_COUNT
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: appStore.rating.toFixed(1),
          ratingCount: appStore.ratingCount,
          bestRating: "5",
        },
      }
    : {}),
};
---

<Layout title={title} description={description} canonical={`${SITE}/`}>
  <Fragment slot="head">
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="alternate" hreflang="pt-BR" href={`${SITE}/`} />
    <link rel="alternate" hreflang="en" href={`${SITE}/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE}/`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}/images/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${SITE}/`} />
    <meta property="og:site_name" content="MeuGrana" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}/images/og-image.png`} />

    <!-- AI crawler metadata -->
    <link rel="alternate" type="text/plain" href={`${SITE}/llms.txt`} title="LLM-friendly site summary" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <Navbar />

  <main>
    <Hero rating={appStore.rating} ratingCount={appStore.ratingCount} />
    <Features />
    <HowItWorks />
    <Screenshots />
    <Testimonials rating={appStore.rating} ratingCount={appStore.ratingCount} />
    <Premium />
    <Faq />
    <DownloadCta />
  </main>

  <Footer />

  <script is:inline src="js/main.js"></script>
</Layout>
