---
import { APP_STORE_URL, APP_STORE_BADGE_URL } from "../consts";
---

<section class="hero">
  <div class="hero-content">
    <img src="images/app-icon.png" alt="MeuGrana app icon" class="hero-icon" width="100" height="100" />
    <h1>MeuGrana</h1>
    <p class="tagline" data-i18n="hero.tagline">Controle seus gastos e parcelas</p>
    <p class="subtitle" data-i18n="hero.subtitle">
      O app de finanças feito para o jeito brasileiro de lidar com dinheiro. Acompanhe parcelas,
      cartões de crédito e projete suas faturas futuras.
    </p>
    <a href={APP_STORE_URL} class="app-store-badge" aria-label="Download on the App Store">
      <img src={APP_STORE_BADGE_URL} alt="Download on the App Store" height="54" />
    </a>
    <div class="phone-frame hero-screenshot">
      <img
        src="images/screenshots/pt-BR/screenshot-1.png"
        alt="MeuGrana Dashboard"
        data-screenshot="1"
        width="320"
        height="695"
        loading="eager"
      />
    </div>
  </div>
</section>
