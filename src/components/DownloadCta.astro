---
import { APP_STORE_URL, APP_STORE_BADGE_URL } from "../consts";
---

<section class="download-cta" id="download" aria-label="Download">
  <div class="container fade-in">
    <h2 data-i18n="cta.title">Comece a controlar seu dinheiro hoje</h2>
    <p data-i18n="cta.subtitle">Baixe o MeuGrana gratuitamente e veja para onde vai cada real.</p>
    <a href={APP_STORE_URL} class="app-store-badge" aria-label="Download on the App Store">
      <img src={APP_STORE_BADGE_URL} data-badge alt="Download on the App Store" height="54" />
    </a>
    <p class="hero-microcopy" data-i18n="hero.microcopy">
      Grátis para baixar · Sem cadastro · Dados só no seu iPhone
    </p>
  </div>
</section>
