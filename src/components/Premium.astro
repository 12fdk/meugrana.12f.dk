---
const premiumFeatures = [
  { key: "premium.feature1", text: "Cartões e parcelas ilimitados" },
  { key: "premium.feature2", text: "Projeção de 12 meses" },
  { key: "premium.feature3", text: "Categorias personalizadas" },
  { key: "premium.feature4", text: "Relatórios e tendências" },
  { key: "premium.feature5", text: "Exportação CSV" },
  { key: "premium.feature6", text: "Widgets extras" },
];
---

<section class="premium" id="premium" aria-label="Premium">
  <div class="container">
    <div class="premium-card fade-in">
      <h2 data-i18n="premium.title">MeuGrana Premium</h2>
      <p class="premium-subtitle" data-i18n="premium.subtitle">Desbloqueie todo o potencial do app.</p>
      <div class="premium-features">
        {
          premiumFeatures.map((f) => (
            <div class="premium-feature">
              <span class="check">&#10003;</span>
              <span data-i18n={f.key}>{f.text}</span>
            </div>
          ))
        }
      </div>
      <p class="premium-price" data-i18n="premium.price">A partir de R$ 14,90/mês</p>
    </div>
  </div>
</section>
