---
// Site navigation. On the homepage it shows section links + language toggle;
// on other pages just the brand linking back home. Pass `root` on pages
// outside the homepage so section anchors resolve against "/".
interface Props {
  minimal?: boolean;
  /** Set true on non-homepage pages (e.g. blog) to prefix anchors with "/". */
  root?: boolean;
}

const { minimal = false, root = false } = Astro.props;
const prefix = root ? "/" : "";

const links = [
  { hash: "#features", key: "nav.features", text: "Recursos" },
  { hash: "#how-it-works", key: "nav.how", text: "Como funciona" },
  { hash: "#screenshots", key: "nav.screenshots", text: "Capturas" },
  { hash: "#premium", key: "nav.premium", text: "Premium" },
  { hash: "#faq", key: "nav.faq", text: "FAQ" },
  { hash: "#download", key: "nav.download", text: "Baixar" },
];
---

<header>
  <nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="container">
      <a href={minimal || root ? "/" : "#"} class="nav-brand">
        <img src="/images/app-icon.png" alt="MeuGrana" width="36" height="36" />
        MeuGrana
      </a>
      {
        !minimal && (
          <>
            <button
              class="mobile-nav-toggle"
              id="mobile-nav-toggle"
              aria-label="Menu"
              aria-expanded="false"
            >
              <span />
              <span />
              <span />
            </button>
            <ul class="nav-links" id="nav-links">
              {links.map((l) => (
                <li>
                  <a href={`${prefix}${l.hash}`} data-i18n={l.key}>
                    {l.text}
                  </a>
                </li>
              ))}
              <li>
                <a href="/blog/" class="nav-blog-link">
                  Blog
                </a>
              </li>
              <li>
                <button
                  class="lang-btn"
                  id="lang-toggle"
                  onclick="toggleLanguage()"
                  aria-label="Switch to English"
                >
                  EN
                </button>
              </li>
            </ul>
          </>
        )
      }
    </div>
  </nav>
</header>
